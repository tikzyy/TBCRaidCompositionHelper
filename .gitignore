# =========================================================
#  .gitignore — FastAPI (Python) backend + React frontend
# =========================================================

# ---- Environment / secrets  ----
.env
.env.local
.env.*.local
.env.development.local
.env.production.local

# ---- Python (backend) ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Node / React (frontend) ----
node_modules/
dist/
build/
.vite/
*.local

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Test / coverage output ----
coverage/
htmlcov/
.coverage
.coverage.*

# ---- Smoke test artifacts ----
smoke-*.png

# ---- OS cruft ----
.DS_Store
Thumbs.db

# ---- Editor / IDE ----
.idea/
*.swp
*.swo
.vscode/